<!DOCTYPE html>
<html lang="id">
<head>
    <style>
        :root { --bg-color: #f8fafc; --sidebar-bg: #ffffff; --card-bg: #ffffff; --text-color: #1e293b; --text-secondary: #64748b; --primary-color: #2563eb; --border-color: #e2e8f0; --shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1); }
        [data-theme="dark"] { --bg-color: #0f172a; --sidebar-bg: #1e293b; --card-bg: #1e293b; --text-color: #f1f5f9; --text-secondary: #94a3b8; --primary-color: #3b82f6; --border-color: #334155; --shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.3); }
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Inter', sans-serif; transition: background-color 0.3s, color 0.3s; }
        body { background-color: var(--bg-color); color: var(--text-color); display: flex; min-height: 100vh; }
        aside { width: 260px; background: var(--sidebar-bg); border-right: 1px solid var(--border-color); padding: 2rem 1.5rem; position: fixed; height: 100vh; }
        .logo { font-size: 1.5rem; font-weight: 800; color: var(--primary-color); margin-bottom: 2.5rem; }
        .nav-menu { list-style: none; }
        .nav-item { padding: 12px 15px; border-radius: 10px; cursor: pointer; margin-bottom: 8px; display: flex; align-items: center; gap: 12px; color: var(--text-secondary); font-weight: 500; text-decoration: none; }
        .nav-item:hover, .nav-item.active { background: var(--primary-color); color: white; }
        main { flex: 1; margin-left: 260px; padding: 2rem 5%; }
        header { display: flex; justify-content: flex-end; margin-bottom: 2rem; position: relative; }
        .user-profile-trigger { display: flex; align-items: center; gap: 10px; cursor: pointer; background: var(--card-bg); padding: 8px 16px; border-radius: 50px; border: 1px solid var(--border-color); box-shadow: var(--shadow); }
        .user-profile-trigger img { width: 35px; height: 35px; border-radius: 50%; object-fit: cover; }
        #accountPopup { position: absolute; top: 60px; right: 0; width: 250px; background: var(--card-bg); border-radius: 15px; border: 1px solid var(--border-color); box-shadow: var(--shadow); padding: 20px; display: none; z-index: 1001; }
        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 20px; }
        .product-card { background: var(--card-bg); border-radius: 15px; padding: 15px; border: 1px solid var(--border-color); }
        .product-card img { width: 100%; height: 140px; object-fit: cover; border-radius: 10px; margin-bottom: 10px; }
        .btn-edit { width: 100%; background: #f1f5f9; color: #1e293b; border: none; padding: 8px; border-radius: 8px; font-size: 0.8rem; cursor: pointer; margin-top: 10px; }
        .search-bar { width: 100%; max-width: 400px; padding: 12px 40px; border-radius: 12px; border: 1px solid var(--border-color); background: var(--card-bg); color: var(--text-color); margin-bottom: 25px; }

    </style>
    </head>
<body data-theme="light">
    <aside>
        <div class="logo">TrustScan.id</div>
        <ul class="nav-menu">
            <a href="umkm-dasbor.html" class="nav-item"><i class="fas fa-th-large"></i> Dasbor</a>
            <a href="umkm-tambah-produk.html" class="nav-item"><i class="fas fa-plus-circle"></i> Tambah Produk</a>
            <a href="umkm-sertifikasi.html" class="nav-item"><i class="fas fa-certificate"></i> Sertifikasi</a>
            <a href="umkm-produksi.html" class="nav-item active"><i class="fas fa-calendar-check"></i> Produksi Hari Ini</a>
            <a href="umkm-sosmed.html" class="nav-item"><i class="fas fa-share-alt"></i> Media Sosial</a>
        </ul>
    </aside>
    <main>
        <h2>Produksi Hari Ini</h2>
        <p style="color: var(--text-secondary);">Catat jumlah produksi harian untuk transparansi konsumen.</p>
        <div class="form-grid" style="margin-top: 20px; background: white; padding: 20px; border-radius: 15px; border: 1px solid #ddd;">
            <div class="form-group">
                <label>Pilih Produk</label>
                <select><option>Basreng Pedas</option></select>
            </div>
            <div class="form-group">
                <label>Jumlah Produksi (Pcs/Box)</label>
                <input type="number" placeholder="Contoh: 50">
            </div>
            <button class="btn-primary">Simpan Laporan</button>
        </div>
    </main>
</body>
</html>